import numpy as np

try:
    import scipy.fft as _sfft           # multithreaded pocketfft

    def _rfft2(a):
        return _sfft.rfft2(a, workers=-1)

    def _irfft2(ah, shape):
        return _sfft.irfft2(ah, s=shape, workers=-1)
except Exception:                        # fallback to numpy
    def _rfft2(a):
        return np.fft.rfft2(a)

    def _irfft2(ah, shape):
        return np.fft.irfft2(ah, s=shape)

